@{
    ViewData["Title"] = ViewBag.ReferenceMode is true ? "Reference character builder" : "Character sheet";
    ViewData["BodyClass"] = "sheet-body sheet-interactive";
    string roomCode = ViewBag.RoomCode as string ?? "";
    bool readOnly = ViewBag.ReadOnly is bool ro && ro;
    bool referenceMode = ViewBag.ReferenceMode is true;
    string title = referenceMode ? "Reference character builder" : (readOnly ? "Player sheet (read-only)" : "Character sheet");
}

<header class="gm-toolbar screen-only">
    <span class="gm-toolbar__title">@title — @roomCode</span>
    <a href="/room/@roomCode/gm/sheets" class="gm-btn">Back to sheets</a>
    @if (!referenceMode)
    {
        <a href="/room/@roomCode/gm" class="gm-btn">GM panel</a>
    }
</header>

<partial name="_InteractiveSheetShell" />

@section Scripts {
    @{
        ViewBag.SheetMode = "sheet";
    }
    <partial name="_InteractiveSheetScripts" />
}
