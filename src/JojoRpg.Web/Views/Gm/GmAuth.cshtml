@{
    Layout = "_Layout";
    ViewData["Title"] = "GM Auth";
    string roomCode = ViewBag.RoomCode as string ?? "";
}

<main class="auth-page">
    <section class="auth-card">
    <h1>GM access — @roomCode</h1>
    @if (TempData["Error"] is string error)
    {
        <p class="auth-error">@error</p>
    }
    <p class="auth-intro">Enter your GM code to open this room. If this room is linked to your account, signing in will skip this step.</p>
    <form method="post" action="/room/@roomCode/gm/auth" class="auth-form">
        <label class="auth-field">
            <span>GM code</span>
            <input class="auth-input auth-input--code" type="password" name="gmCode" required autocomplete="off" />
        </label>
        <button type="submit" class="auth-btn">Authenticate</button>
    </form>
    <p class="auth-alt"><a href="/account/login?returnUrl=@Uri.EscapeDataString($"/room/{roomCode}/gm")">Sign in with account</a></p>
    </section>
</main>
