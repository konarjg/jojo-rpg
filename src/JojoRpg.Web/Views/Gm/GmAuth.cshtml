@{
    Layout = "_Layout";
    ViewData["Title"] = "GM Auth";
    string roomCode = ViewBag.RoomCode as string ?? "";
}

<main style="max-width:480px;margin:2rem auto;padding:1rem;">
    <h1>GM access — @roomCode</h1>
    @if (TempData["Error"] is string error)
    {
        <p style="color:#c44;">@error</p>
    }
    <p>Enter your GM code to open this room.</p>
    <form method="post" action="/room/@roomCode/gm/auth">
        <label>GM code <input type="password" name="gmCode" required autocomplete="off" /></label>
        <button type="submit">Authenticate</button>
    </form>
</main>
