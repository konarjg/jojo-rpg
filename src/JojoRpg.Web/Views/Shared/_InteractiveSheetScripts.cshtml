@{
    string roomCode = ViewBag.RoomCode as string ?? "";
    Guid? roomId = ViewBag.RoomId as Guid?;
    Guid? playerId = ViewBag.PlayerId as Guid?;
    string mode = ViewBag.SheetMode as string ?? "sheet";
    bool readOnly = ViewBag.ReadOnly is bool ro && ro;
    bool referenceMode = ViewBag.ReferenceMode is bool rm && rm;
    string storageMode = referenceMode ? "local" : "server";
    string roomIdValue = roomId?.ToString() ?? "";
    string playerIdValue = playerId?.ToString() ?? "";
}
<script>
    window.JOJO_CONFIG = {
        roomId: '@roomIdValue',
        roomCode: '@roomCode',
        playerId: '@playerIdValue',
        mode: '@mode',
        readOnly: @readOnly.ToString().ToLowerInvariant(),
        referenceMode: @referenceMode.ToString().ToLowerInvariant()
    };
    window.JOJO_STORAGE_MODE = '@storageMode';
</script>
<script src="~/vendor/marked.min.js"></script>
<script src="~/vendor/purify.min.js"></script>
<script src="~/js/legacy/markdown-render.js"></script>
<script src="~/js/legacy/dice-roller.js" asp-append-version="true"></script>
<script src="~/js/legacy/sheet-app.js" asp-append-version="true"></script>
