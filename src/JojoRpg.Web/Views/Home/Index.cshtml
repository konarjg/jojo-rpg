@{
    ViewData["Title"] = "JoJo RPG";
}

<main class="auth-page home-page">
    <section class="auth-card">
    <h1>JoJo RPG</h1>
    @if (TempData["Error"] is string error)
    {
        <p class="auth-error">@error</p>
    }

    @if (Context.GetAccount() is not null)
    {
        <p><a class="auth-btn" href="/account">Open my campaigns</a></p>
    }

    <section class="account-section account-section--embedded">
        <h2>Create campaign (GM)</h2>
        <form method="post" action="/rooms" class="auth-form">
            <label class="auth-field">
                <span>Campaign name</span>
                <input class="auth-input" type="text" name="name" placeholder="Campaign" autocomplete="off" />
            </label>
            <button type="submit" class="auth-btn">Create room</button>
        </form>
    </section>

    <section class="account-section account-section--embedded">
        <h2>Join as player</h2>
        <form method="post" action="/join" class="auth-form">
            <label class="auth-field">
                <span>Room code</span>
                <input class="auth-input auth-input--code" type="text" name="roomCode" required maxlength="16" autocomplete="off" placeholder="e.g. ABC12345" />
            </label>
            <label class="auth-field">
                <span>Display name</span>
                <input class="auth-input" type="text" name="displayName" required maxlength="128" placeholder="Your name" autocomplete="name" />
            </label>
            <label class="auth-field">
                <span>Player code <small>(optional — rejoin an existing character)</small></span>
                <input class="auth-input auth-input--code" type="text" name="playerCode" maxlength="16" autocomplete="off" placeholder="Leave blank for a new character" />
            </label>
            <button type="submit" class="auth-btn">Join</button>
        </form>
        <p class="auth-intro">Your player code is saved in this browser after your first join. Sign in to rejoin from another device without the code.</p>
    </section>

    <form method="post" action="/session/leave" class="auth-form">
        <button type="submit" class="auth-btn auth-btn--secondary">Leave session</button>
    </form>
    </section>
</main>
