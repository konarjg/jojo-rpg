@{
    Layout = "_Layout";
    ViewData["Title"] = "Join";
    string roomCode = ViewBag.RoomCode as string ?? "";
    string? savedPlayerCode = ViewBag.SavedPlayerCode as string;
}

<main class="auth-page">
    <section class="auth-card">
    <h1>Join room @roomCode</h1>
    @if (ViewBag.Error is string error)
    {
        <p class="auth-error">@error</p>
    }
    <form method="post" action="/room/@roomCode/join" class="auth-form">
        <label class="auth-field">
            <span>Display name</span>
            <input class="auth-input" type="text" name="displayName" required maxlength="128" placeholder="Your name" autocomplete="name" />
        </label>
        <label class="auth-field">
            <span>Player code <small>(optional)</small></span>
            <input class="auth-input auth-input--code" type="text" name="playerCode" maxlength="16" autocomplete="off" value="@savedPlayerCode" placeholder="Saved automatically in this browser" />
        </label>
        <button type="submit" class="auth-btn">Join</button>
    </form>
    <p class="auth-intro">Leave player code blank to create a new character. If you are signed in, your account will remember this character on other devices.</p>
    </section>
</main>
