@{
    ViewData["Title"] = "Player view";
    ViewData["BodyClass"] = "sheet-body sheet-interactive";
    string roomCode = ViewBag.RoomCode as string ?? "";
    Guid roomId = ViewBag.RoomId;
}

<div id="play-app" data-room-id="@roomId" data-room-code="@roomCode">
    <header class="gm-toolbar screen-only">
        <span class="gm-toolbar__title">Player view — @roomCode</span>
        @if (ViewBag.IsGm is true)
        {
            <a href="/room/@roomCode/gm" class="gm-btn">GM panel</a>
        }
        else
        {
            <a href="/room/@roomCode/play" class="gm-btn">My sheet</a>
        }
    </header>
    <div id="player-roll-banner" class="player-roll-banner" hidden></div>
    <div id="player-map-panel" class="player-map-panel">
        <h2 id="player-map-title" hidden></h2>
        <div id="player-map-canvas" class="gm-map-canvas player-map-canvas"></div>
    </div>
</div>

@section Scripts {
    <script>
        window.JOJO_CONFIG = { roomId: '@roomId', roomCode: '@roomCode', mode: 'player-view' };
        window.JOJO_STORAGE_MODE = 'server';
    </script>
    <script src="~/js/play.js" asp-append-version="true"></script>
}
