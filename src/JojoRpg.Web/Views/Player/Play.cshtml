@{
    ViewData["Title"] = "Play";
    ViewData["BodyClass"] = "sheet-body sheet-interactive play-mode";
    string roomCode = ViewBag.RoomCode as string ?? "";
    Guid roomId = ViewBag.RoomId;
    Guid? playerId = ViewBag.PlayerId as Guid?;
}

<div id="play-app" data-room-id="@roomId" data-room-code="@roomCode" data-player-id="@playerId">
    <header class="gm-toolbar screen-only">
        <span class="gm-toolbar__title">JoJo RPG — @roomCode</span>
        <form method="post" action="/session/leave" style="display:inline"><button type="submit" class="gm-btn">Leave</button></form>
    </header>
    <div id="player-roll-banner" class="player-roll-banner" hidden></div>
    <div class="play-layout" id="play-layout">
        <div class="play-main">
            <partial name="_InteractiveSheetShell" />
            <div id="player-sticky-panel" class="gm-stickies-board" hidden></div>
        </div>
        <aside id="player-map-panel" class="play-map-sidebar play-map-sidebar--closed" aria-hidden="true">
            <section class="gm-panel-section gm-map-section">
                <div class="gm-section-head">
                    <h2 id="player-map-title">Shared map</h2>
                </div>
                <div id="player-map-canvas" class="gm-map-canvas player-map-canvas"></div>
            </section>
        </aside>
    </div>
</div>

@section Scripts {
    @{
        ViewBag.SheetMode = "play";
        ViewBag.RoomId = roomId;
    }
    <script>
        window.JOJO_CONFIG = { roomId: '@roomId', roomCode: '@roomCode', playerId: '@playerId', mode: 'play', readOnly: false, referenceMode: false };
        window.JOJO_STORAGE_MODE = 'server';
    </script>
    <script src="~/js/play.js" asp-append-version="true"></script>
    <script src="~/vendor/marked.min.js"></script>
    <script src="~/vendor/purify.min.js"></script>
    <script src="~/js/legacy/markdown-render.js"></script>
    <script src="~/js/legacy/dice-roller.js" asp-append-version="true"></script>
    <script src="~/js/legacy/sheet-app.js" asp-append-version="true"></script>
}
